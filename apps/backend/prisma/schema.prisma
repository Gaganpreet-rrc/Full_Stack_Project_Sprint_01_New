generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  clerkId  String @unique
  name     String
  email    String @unique
  books    Book[]
  
  searches SearchFilter[]
}

model SearchFilter {
  id   Int    @id @default(autoincrement())
  term String
  
  userId Int
  user   User @relation(fields: [userId], references: [id])
}

model Book {
  id     Int    @id @default(autoincrement())
  title  String
  author String
  userId Int?
  user   User?  @relation(fields: [userId], references: [id])
}

