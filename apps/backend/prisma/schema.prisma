generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
  password String
  books    Book[]
}

model Book {
  id      Int     @id @default(autoincrement())
  title   String
  author  String
  userId  Int?
  user    User?    @relation(fields: [userId], references: [id])
}